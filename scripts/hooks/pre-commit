#!/bin/bash
# Auto-bump patch version on every commit
# Follows Semantic Versioning (semver.org):
#   MAJOR.MINOR.PATCH
#   - PATCH: auto-incremented on every commit
#   - MINOR: bump manually for new features (reset PATCH to 0)
#   - MAJOR: bump manually for breaking changes (reset MINOR + PATCH to 0)

PLUGIN_JSON=".claude-plugin/plugin.json"
MARKETPLACE_JSON=".claude-plugin/marketplace.json"

# Skip if plugin.json is not in the repo
if [ ! -f "$PLUGIN_JSON" ]; then
  exit 0
fi

# Read current version from HEAD (last committed version)
HEAD_VERSION=$(git show HEAD:"$PLUGIN_JSON" 2>/dev/null | grep '"version"' | head -1 | sed 's/.*"\([0-9]*\.[0-9]*\.[0-9]*\)".*/\1/')

# Read current version from working tree
CURRENT=$(grep '"version"' "$PLUGIN_JSON" | head -1 | sed 's/.*"\([0-9]*\.[0-9]*\.[0-9]*\)".*/\1/')

if [ -z "$CURRENT" ]; then
  exit 0
fi

# If version was manually changed (differs from HEAD), respect it and skip auto-bump
if [ -n "$HEAD_VERSION" ] && [ "$HEAD_VERSION" != "$CURRENT" ]; then
  echo "Version manually set: ${HEAD_VERSION} → ${CURRENT} (skipping auto-bump)"
  # Still sync marketplace.json if needed
  if [ -f "$MARKETPLACE_JSON" ]; then
    sed -i '' "s/\"version\": \"${HEAD_VERSION}\"/\"version\": \"${CURRENT}\"/g" "$MARKETPLACE_JSON"
    git add "$MARKETPLACE_JSON" 2>/dev/null
  fi
  exit 0
fi

# Auto-bump patch
MAJOR=$(echo "$CURRENT" | cut -d. -f1)
MINOR=$(echo "$CURRENT" | cut -d. -f2)
PATCH=$(echo "$CURRENT" | cut -d. -f3)

PATCH=$((PATCH + 1))
NEW_VERSION="${MAJOR}.${MINOR}.${PATCH}"

# Update plugin.json
sed -i '' "s/\"version\": \"${CURRENT}\"/\"version\": \"${NEW_VERSION}\"/" "$PLUGIN_JSON"

# Update marketplace.json
if [ -f "$MARKETPLACE_JSON" ]; then
  sed -i '' "s/\"version\": \"${CURRENT}\"/\"version\": \"${NEW_VERSION}\"/" "$MARKETPLACE_JSON"
fi

# Stage version changes
git add "$PLUGIN_JSON" "$MARKETPLACE_JSON" 2>/dev/null

echo "Version auto-bumped: ${CURRENT} → ${NEW_VERSION}"
